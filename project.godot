; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Monkey Mountain"
config/description="First Game!"
run/main_scene="uid://gkmj3eyei7op"
config/features=PackedStringArray("4.5", "Mobile")
config/icon="uid://coruu7ywfc5l8"

[autoload]

BackgroundMusic="*res://background_music.tscn"
GameManager="*res://game_levels/level_transition/scene_transition.tscn"
Main_DeathScreenMusic="*res://death_screen_music.tscn"

[display]

window/size/viewport_width=1400
window/size/viewport_height=900
window/size/resizable=false

[global_group]

boulders=""
Player=""
Enemy=""
Enemy_Timer=""
delete_enemy_area=""
Pivot=""
Wall_Pivot=""

[input]

punch_action={
"deadzone": 0.2,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":68,"key_label":0,"unicode":100,"location":0,"echo":false,"script":null)
]
}
pause={
"deadzone": 0.2,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":0,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":80,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}

[layer_names]

2d_physics/layer_1="player"
2d_navigation/layer_1="Foreground"
2d_physics/layer_2="objects"
2d_navigation/layer_2="Midground"
2d_physics/layer_3="enemy"
2d_navigation/layer_3="Background"
2d_physics/layer_4="floor"
2d_physics/layer_5="enemy_pivot"
2d_physics/layer_6="bounce"
2d_physics/layer_7="wall"
2d_physics/layer_10="items"
2d_physics/layer_11="regular_wall"
2d_physics/layer_16="spikes"
2d_physics/layer_17="death"

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
anti_aliasing/screen_space_roughness_limiter/enabled=false
